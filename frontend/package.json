{
  "name": "@linguisticnode/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "metro": "~0.80.9",
    "metro-resolver": "~0.80.9",
    "metro-config": "~0.80.9"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/specs/smoke.spec.ts",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "tsc -b",
    "test:ci": "npm run lint && npm run typecheck && npm run test -- --run && npm run build",
    "test:e2e:ci": "RUN_VISUAL_REGRESSION=1 playwright test --project=chromium --project=firefox",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:visual": "RUN_VISUAL_REGRESSION=1 playwright test e2e/specs/ui-regression.spec.ts",
    "test:e2e:rnw-poc": "RUN_VISUAL_REGRESSION=1 playwright test e2e/specs/rnw-poc.spec.ts",
    "test:e2e:visual:update": "RUN_VISUAL_REGRESSION=1 playwright test e2e/specs/ui-regression.spec.ts --update-snapshots",
    "test:mobile:regression": "vitest run src/__tests__/mobile/mobileRegressionFlow.test.ts src/__tests__/mobile/mobileSyncGateway.test.ts src/__tests__/mobile/mobileLearningRepository.test.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bootstrap": "^5.3.8",
    "expo-document-picker": "~13.0.3",
    "expo-sharing": "~13.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.84.0",
    "react-native-web": "^0.21.2",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.10.1",
    "@types/react": "~18.3.0",
    "@types/react-dom": "~18.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  }
}
