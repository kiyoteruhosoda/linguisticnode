{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "baseUrl": "../..",
    "paths": {
      "@linguisticnode/core": ["./packages/core/src/index.ts"],
      "@linguisticnode/core/*": ["./packages/core/src/*"]
    }
  },
  "include": [
    "src",
    "App.tsx",
    "app.config.ts",
    "../../src/types/**/*.d.ts"
  ]
}
